---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import ReviewsModal from "../components/ReviewsModal.svelte";

import bookCover1 from "../assets/images/VIDA_de_un_culo_inquieto_Portada.webp";
import bookCover2 from "../assets/images/A_muerte_con_la_VIDA_portada.webp";
import bookCover3 from "../assets/images/nuevo_libro_2027.png";
import heroImg from "../assets/images/PRINT_AnaAlbiol_EA-31.webp";

const showNewBook = false;

const reviewsBook1 = [
    "Este libro es un mazazo de realidad escrito desde el humor y el respeto. No es un libro para evadirse, es un libro para mirar hacia dentro.",
    "Me recordó algo muy importante: la vida nunca me pidió que fuera perfecta. Soltar, saltar y confiar no es solo para otros. Yo también puedo.",
    "Es como si estuvieras hablando con una amiga. Ríes con ella a carcajada limpia y otras veces no puedes dejar de llorar.",
    "Una revelación constante sobre nuestras propias limitaciones autoimpuestas.",
    "La forma en que Ana describe el 'culo inquieto' es exactamente como me siento cada mañana.",
    "No pude parar de leer hasta terminarlo, y ahora siento que algo ha cambiado en mí.",
    "Honesto, brutal y necesario en tiempos de tanto postureo.",
    "Me ha dado el empujón que necesitaba para tomar esa decisión que llevaba meses postergando.",
    "Es un viaje emocional sin filtros. Totalmente recomendable.",
    "Hacía mucho tiempo que un libro no me hacía sentir tan comprendida.",
    "Como un café largo con una amiga sabia que no te juzga.",
    "Lo he subrayado tanto que casi es todo amarillo. Oro puro."
];

const reviewsBook2 = [
    "No es un libro, es un espejo. Te permite mirar desde tus brillos hasta tus miserias de una forma activa y constructiva.",
    "Es un libro para tener cerca de la cama y leer poco a poco. Cada frase, cada palabra en negrita tiene un porqué.",
    "Al final, todo se resume en una cosa: tú decides si te quedas donde estás o te acercas a la vida que quieres vivir.",
    "Atravesar el cambio da miedo, pero este libro te da la mano durante todo el proceso.",
    "Suelta, salta y confía: parece fácil pero aquí Ana te explica el porqué de cada paso.",
    "Me pilló en un momento vital de crisis y fue mi mejor guía de supervivencia.",
    "La profundidad de estas páginas contrasta con la sencillez de su lenguaje. Brillante.",
    "Un manual de vida para los que no queremos una vida a medias.",
    "Ana Albiol lo ha vuelto a hacer. Verdad pura en cada línea.",
    "Es imposible leerlo y quedarse igual. Te remueve los cimientos.",
    "Una lectura imprescindible para cualquiera que se sienta estancado.",
    "Me ha enseñado a gestionar la incertidumbre con una paz que no conocía."
];
---

<Layout
    title="Mis Libros | Ana Albiol"
    description="Libros de Ana Albiol: 'Vida de un culo inquieto' y 'A muerte con la vida'. Lecturas para soltar, saltar y confiar."
    headerTheme="light"
>
    <!-- Hero Editorial -->
    <section class="hero-editorial">
        <div class="background-text">LIBROS</div>
        
        <div class="container hero-wrapper">
            <div class="hero-text-content">
                <div class="label-wrapper fade-element">
                    <span class="hero-label">Mis Publicaciones</span>
                </div>

                <div class="quote-main fade-element">
                    <blockquote class="hero-quote">
                        <p class="quote-upper">
                            Escribí lo que me hubiera gustado leer 
                            <em>cuando más sola y loca me sentía.</em>
                        </p>
                        <p class="quote-lower">
                            <span class="highlight">Sin filtro. Sin postureo. Con verdad.</span>
                        </p>
                    </blockquote>
                </div>

                <div class="hero-actions fade-element">
                    <a href="#libros" class="btn btn-primary">Descubrir Libros</a>
                    <a href="/en-privado" class="btn">Apúntate a En Privado</a>
                </div>
            </div>

            <div class="hero-visual fade-element">
                <div class="image-container">
                    <Image 
                        src={heroImg} 
                        alt="Ana Albiol" 
                        class="hero-image"
                        widths={[400, 800, heroImg.width]}
                        sizes="(max-width: 1024px) 100vw, 50vw"
                    />
                    <div class="image-accent-border"></div>
                </div>
            </div>
        </div>

        <div class="scroll-wrapper fade-element">
            <div class="scroll-mouse">
                <div class="mouse-wheel"></div>
            </div>
            <span class="scroll-text">Deslizar para descubrir</span>
        </div>
    </section>

    <!-- Book 1 -->
    <section id="libros" class="book-detail fade-up">
        <div class="container">
            <div class="book-item">
                <div class="book-info">
                    <span class="small-text">Libro 1</span>
                    <h3>V.I.D.A. de un culo inquieto</h3>
                    <p class="book-tagline">
                        Un libro para empezar a vivir desde lo que eres, no
                        desde lo que esperan de ti.
                    </p>
                    <p>
                        Si no te conformas con lo que te ha tocado o te han
                        impuesto, si sabes que la VIDA es otra cosa y no quieres
                        quedarte con las ganas de vivirla, puede que te sirva.
                    </p>
                    <a href="https://amzn.eu/d/0gQiuCmZ" target="_blank" rel="noopener noreferrer" class="btn mt-2">Comprar en Amazon</a>
                </div>
                <div class="book-image">
                    <Image
                        src={bookCover1}
                        alt="Portada V.I.D.A. de un culo inquieto"
                        class="book-cover"
                        width={300}
                        height={450}
                    />
                </div>
            </div>

            <div class="review-grid">
                <div class="review-card">
                    "Este libro es un mazazo de realidad escrito desde el humor
                    y el respeto. No es un libro para evadirse, es un libro para
                    mirar hacia dentro."
                </div>
                <div class="review-card">
                    "Me recordó algo muy importante: la vida nunca me pidió que
                    fuera perfecta. Soltar, saltar y confiar no es solo para
                    otros. Yo también puedo."
                </div>
                <div class="review-card">
                    "Es como si estuvieras hablando con una amiga. Ríes con ella
                    a carcajada limpia y otras veces no puedes dejar de llorar."
                </div>
            </div>

            <div style="text-align: center; margin-top: 3rem;">
                <ReviewsModal client:load bookTitle="V.I.D.A. de un culo inquieto" reviews={reviewsBook1} />
            </div>
        </div>
    </section>

    <!-- Book 2 -->
    <section class="book-detail fade-up">
        <div class="container">
            <div class="book-item">
                <div class="book-image">
                    <Image
                        src={bookCover2}
                        alt="Portada A muerte con la V.I.D.A."
                        class="book-cover"
                        width={300}
                        height={450}
                    />
                </div>
                <div class="book-info">
                    <span class="small-text">Libro 2</span>
                    <h3>A muerte con la V.I.D.A.</h3>
                    <p class="book-tagline">
                        Un libro para atravesar procesos de cambio a través de
                        tres palabras clave: <em>suelta, salta y confía.</em>
                    </p>
                    <p>
                        Si estás en crisis, proceso de cambio profundo o
                        replanteamiento vital, puede que te sirva.
                    </p>
                    <a href="https://amzn.eu/d/02e14CbG" target="_blank" rel="noopener noreferrer" class="btn mt-2">Comprar en Amazon</a>
                </div>
            </div>

            <div class="review-grid">
                <div class="review-card">
                    "No es un libro, es un espejo. Te permite mirar desde tus
                    brillos hasta tus miserias de una forma activa y
                    constructiva."
                </div>
                <div class="review-card">
                    "Es un libro para tener cerca de la cama y leer poco a poco.
                    Cada frase, cada palabra en negrita tiene un porqué."
                </div>
                <div class="review-card">
                    "Al final, todo se resume en una cosa: tú decides si te
                    quedas donde estás o te acercas a la vida que quieres
                    vivir."
                </div>
            </div>

            <div style="text-align: center; margin-top: 3rem;">
                <ReviewsModal client:load bookTitle="A muerte con la V.I.D.A." reviews={reviewsBook2} />
            </div>
        </div>
    </section>

    <!-- New Book Teaser -->
    {showNewBook && (
    <section class="coming-soon fade-up">
        <div class="container">
            <div class="book-item">
                <div class="book-info">
                    <span
                        class="small-text"
                        style="color: rgba(255,255,255,0.8);"
                        >Próximo Lanzamiento</span
                    >
                    <h2>Nuevo Libro</h2>
                    <p class="subtitle">Enero 2027</p>
                    <p style="color: white; margin-bottom: 2rem;">
                        Después de vivir el cambio en mi cuerpo serrano y
                        trabajar con más de 3000 personas para que logren el
                        suyo, este libro propone el método que he desarrollado.
                        Un viaje profundo para dejar de sobrevivir y empezar a
                        VIVIR.
                    </p>
                    <a href="/en-privado" class="btn btn-inverted"
                        >Sigue el proceso desde dentro</a
                    >
                </div>
                <div class="book-image">
                    <Image
                        src={bookCover3}
                        alt="Mockup del nuevo libro 2027"
                        class="book-cover"
                        width={300}
                        height={450}
                    />
                </div>
            </div>
        </div>
    </section>
    )}
</Layout>

<script>
    import { inView, animate } from "motion";

    function initLibrosAnimations() {
        const heroElements = document.querySelectorAll(
            ".hero-editorial .fade-element",
        );

        animate(
            heroElements,
            { opacity: [0, 1], y: [40, 0] },
            {
                delay: 0.3,
                duration: 0.8,
                easing: [0.17, 0.67, 0.83, 0.67],
            },
        );

        const heroVisual = document.querySelector(".hero-visual");
        if (heroVisual) {
            animate(
                heroVisual,
                { opacity: [0, 1], x: [100, 0] },
                { delay: 0.5, duration: 1.2, easing: [0.17, 0.67, 0.83, 0.67] }
            );
        }

        const bgText = document.querySelector(".background-text");
        if (bgText) {
            animate(
                bgText,
                { opacity: [0, 0.03], scale: [0.8, 1] },
                { delay: 0.2, duration: 2, easing: "ease-out" }
            );
        }
    }

    initLibrosAnimations();
    document.addEventListener("astro:after-swap", initLibrosAnimations);
</script>

<style>
    /* ========================================
       HERO EDITORIAL PREMIUM
       ======================================== */
    .hero-editorial {
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        background-color: var(--color-secondary);
        overflow: hidden;
        padding: 140px 0 100px;
    }

    .background-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: var(--font-heading);
        font-size: 25vw;
        font-weight: 900;
        color: var(--color-primary);
        opacity: 0;
        white-space: nowrap;
        pointer-events: none;
        z-index: 0;
    }

    .hero-wrapper {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: center;
        gap: 4rem;
        position: relative;
        z-index: 2;
    }

    .hero-text-content {
        max-width: 750px;
    }

    .hero-label {
        display: inline-block;
        font-family: var(--font-body);
        text-transform: uppercase;
        letter-spacing: 5px;
        font-size: 0.8rem;
        margin-bottom: 2rem;
        color: var(--color-primary);
        border-bottom: 1px solid rgba(150, 79, 76, 0.3);
        padding-bottom: 0.5rem;
    }

    .hero-quote {
        margin: 0 0 3rem;
        position: relative;
    }

    .quote-upper {
        font-family: var(--font-heading);
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        line-height: 1.4;
        color: var(--color-text-light);
        margin-bottom: 1.5rem;
        font-style: normal;
    }

    .quote-upper em {
        font-style: normal;
        color: var(--color-primary);
    }

    .quote-lower {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 1.1;
        color: var(--color-primary);
        font-weight: 500;
    }

    .highlight {
        position: relative;
        display: inline;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .hero-visual {
        position: relative;
        opacity: 0;
    }

    .image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 4/5;
        border-radius: 4px;
        overflow: visible;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 4px;
        position: relative;
        z-index: 2;
        filter: sepia(20%) contrast(105%);
        box-shadow: 30px 30px 60px rgba(0, 0, 0, 0.1);
    }

    .image-accent-border {
        position: absolute;
        top: -20px;
        right: -20px;
        width: 100%;
        height: 100%;
        border: 1px solid var(--color-primary);
        opacity: 0.2;
        z-index: 1;
        border-radius: 4px;
    }

    .scroll-wrapper {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        z-index: 3;
    }

    .scroll-mouse {
        width: 24px;
        height: 40px;
        border: 2px solid var(--color-primary);
        border-radius: 12px;
        position: relative;
        opacity: 0.6;
    }

    .mouse-wheel {
        width: 4px;
        height: 8px;
        background-color: var(--color-primary);
        border-radius: 2px;
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        animation: mouseScroll 2s infinite;
    }

    @keyframes mouseScroll {
        0% { transform: translate(-50%, 0); opacity: 1; }
        100% { transform: translate(-50%, 15px); opacity: 0; }
    }

    .scroll-text {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-primary);
        opacity: 0.6;
    }

    /* ========================================
       BOOK SECTIONS
       ======================================== */
    .book-detail {
        padding: 8rem 0;
    }

    .book-detail:nth-child(even) {
        background-color: white;
    }

    .book-item {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
        align-items: center;
        margin-bottom: 4rem;
    }

    @media (min-width: 900px) {
        .book-item {
            grid-template-columns: 1fr 1fr;
        }
    }

    .book-image {
        display: flex;
        justify-content: center;
    }

    .book-cover {
        width: 300px;
        height: auto;
        box-shadow: 20px 20px 40px rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        transition: transform 0.3s ease;
    }

    .book-cover:hover {
        transform: translateY(-5px);
    }

    .book-info h3 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .book-tagline {
        font-size: 1.25rem;
        font-style: normal;
        color: var(--color-primary);
        margin-bottom: 1.5rem;
    }

    .review-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .review-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .review-card {
        background: #fcf9f6;
        padding: 2.5rem;
        border-radius: 12px;
        font-style: normal;
        font-size: 0.95rem;
        color: var(--color-text-light);
        border: 1px solid rgba(0,0,0,0.03);
    }

    .coming-soon {
        padding: 8rem 0;
        background-color: var(--color-primary);
        color: white;
    }

    .coming-soon h2,
    .coming-soon .subtitle,
    .coming-soon p {
        color: white;
    }

    .btn-inverted {
        border-color: white;
        color: white;
    }

    .btn-inverted:hover {
        background-color: white;
        color: var(--color-primary);
        transform: translateY(-2px);
    }

    /* ========================================
       RESPONSIVE
       ======================================== */
    @media (max-width: 1200px) {
        .hero-wrapper {
            gap: 2rem;
        }
        
        .quote-lower {
            font-size: clamp(2rem, 4vw, 3rem);
        }
    }

    @media (max-width: 1024px) {
        .hero-editorial {
            padding: 120px 0 80px;
        }

        .hero-wrapper {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 4rem;
        }

        .hero-text-content {
            max-width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .hero-actions {
            justify-content: center;
        }

        .hero-visual {
            max-width: 500px;
            margin: 0 auto;
        }

        .background-text {
            font-size: 30vw;
        }
    }

    @media (max-width: 768px) {
        .hero-editorial {
            padding: 100px 0 60px;
        }

        .quote-upper {
            font-size: 1.25rem;
        }

        .quote-lower {
            font-size: 2.25rem;
        }
    }

    @media (max-width: 480px) {
        .hero-label {
            letter-spacing: 4px;
            font-size: 0.7rem;
        }

        .hero-actions {
            flex-direction: column;
            width: 100%;
        }

        .hero-actions .btn {
            width: 100%;
        }
    }
</style>
