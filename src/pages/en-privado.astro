---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="En Privado | Ana Albiol"
    description="En Privado. La newsletter de Ana Albiol. Lo que no sale en Instagram. Reflexiones, audios y contenido exclusivo."
    headerTheme="dark"
>
    <!-- Header is in Layout -->

    <!-- Hero -->
    <section class="newsletter-page-hero fade-up">
        <div class="container newsletter-hero-grid">
            <div class="hero-text-column">
                <h1>En Privado</h1>
                <p class="subtitle">
                    Lo que no sale en Instagram. Lo importante. Lo íntimo.
                </p>
            </div>
            <div class="hero-image-column">
                <div class="image-wrapper main-img">
                    <img
                        src="/assets/images/WEB_AnaAlbiol_EA-16.webp"
                        alt="Ana Albiol"
                        class="hero-img"
                    />
                </div>
                <div class="image-wrapper secondary-img">
                    <img
                        src="/assets/images/VIDA_de_un_culo_inquieto_Portada.webp"
                        alt="Vida de un culo inquieto"
                        class="hero-img-sm"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Content -->
    <section class="section-padding">
        <div class="container text-center fade-up">
            <p style="font-size: 1.3rem; max-width: 800px; margin: 0 auto;">
                Para personas que aún valoran el largo y tendido.<br
                />Reflexiones, audios, detalles de cortesía, acceso anticipado a
                las formaciones y directos.
            </p>

            <p class="mt-4" style="font-weight: bold; font-size: 1.2rem;">
                Los sábados, cada 15 días a las 9:00 am en tu bandeja de
                entrada.
            </p>

            <div class="values-grid-large" id="values-grid">
                <div class="value-item">
                    <span class="value-letter">V</span><span class="value-word"
                        >Valores</span
                    >
                </div>
                <div class="value-item">
                    <span class="value-letter">I</span><span class="value-word"
                        >Ilusión</span
                    >
                </div>
                <div class="value-item">
                    <span class="value-letter">D</span><span class="value-word"
                        >Decisión</span
                    >
                </div>
                <div class="value-item">
                    <span class="value-letter">A</span><span class="value-word"
                        >Acción</span
                    >
                </div>
            </div>

            <div class="form-container fade-up">
                <h3>Lo que SÍ</h3>
                <p>Contenido cuidado y personal.</p>
                <hr
                    style="margin: 2rem 0; border: 0; border-top: 1px solid #eee;"
                />
                <h3>Lo que NO</h3>
                <p>
                    Te doy mi palabra de que no voy a bombardear tu correo
                    diariamente para que me tengas presente y poder venderte. <strong
                        >Me horroriza. Y me niego.</strong
                    >
                </p>

                <form class="newsletter-form mt-4" id="newsletter-form">
                    <input
                        type="email"
                        id="newsletter-email"
                        name="email"
                        autocomplete="email"
                        placeholder="Tu mejor email"
                        aria-label="Tu mejor email"
                        required
                        style="border: 1px solid #ddd;"
                    />
                    <button
                        type="submit"
                        class="btn btn-primary"
                        style="width: 100%;">Quiero entrar En Privado</button
                    >
                </form>
            </div>
        </div>
    </section>

    <!-- Footer is in Layout -->
</Layout>

<script>
    import { inView, animate, stagger } from "motion";

    // Values Grid Animation
    const grid = document.getElementById("values-grid");
    if (grid) {
        inView(grid, () => {
            animate(
                grid.querySelectorAll(".value-item"),
                { opacity: [0, 1], y: [30, 0], rotate: [-10, 0] },
                {
                    duration: 0.8,
                    delay: stagger(0.2),
                    easing: [0.175, 0.885, 0.32, 1.275],
                },
            );
        });
    }

    // Form Handling
    const form = document.getElementById("newsletter-form");
    if (form) {
        form.addEventListener("submit", (e) => {
            e.preventDefault();
            alert("¡Gracias por suscribirte!");
        });
    }
</script>

<style>
    .value-item {
        opacity: 0;
    }

    /* Newsletter Page Specific Styles from style.css equivalent not fully covered */
    .newsletter-page-hero {
        background-color: var(--color-primary);
        color: white;
        padding: 10rem 0 6rem;
        text-align: center;
        overflow: hidden;
        position: relative;
    }

    .newsletter-hero-grid {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4rem;
        position: relative;
        z-index: 2;
    }

    @media (min-width: 992px) {
        .newsletter-hero-grid {
            flex-direction: row;
            text-align: left;
            justify-content: space-between;
            gap: 2rem;
        }
        .hero-text-column {
            flex: 1;
        }
        .hero-image-column {
            flex: 1;
            display: flex;
            justify-content: flex-end;
            position: relative;
        }
    }

    .newsletter-page-hero h1 {
        color: white;
        font-size: clamp(3rem, 8vw, 5rem);
        margin-bottom: 1.5rem;
    }

    .newsletter-page-hero .subtitle {
        color: rgba(255, 255, 255, 0.9);
        font-size: clamp(1.2rem, 3vw, 1.8rem);
        max-width: 600px;
        line-height: 1.4;
    }

    .hero-image-column {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
    }

    .image-wrapper {
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    }

    .main-img {
        width: 250px;
        height: 350px;
    }

    .secondary-img {
        width: 150px;
        height: 200px;
        margin-bottom: -2rem;
        display: none;
    }

    @media (min-width: 768px) {
        .main-img {
            width: 300px;
            height: 420px;
        }
        .secondary-img {
            display: block;
        }
    }

    .hero-img,
    .hero-img-sm {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .values-grid-large {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin: 4rem auto;
        max-width: 600px;
    }

    .value-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .value-letter {
        font-family: var(--font-heading);
        font-size: clamp(2.5rem, 10vw, 5rem);
        color: var(--color-primary);
        line-height: 1;
    }

    .value-word {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: clamp(0.6rem, 2vw, 0.9rem);
        color: var(--color-text-light);
    }

    @media (max-width: 400px) {
        .values-grid-large {
            gap: 0.5rem;
        }
    }

    .form-container {
        background: white;
        padding: clamp(1.5rem, 5vw, 3rem);
        border-radius: var(--radius-md);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        max-width: 600px;
        margin: 0 auto;
    }

    .newsletter-form {
        display: flex;
        gap: 1rem;
        flex-direction: column;
    }

    .newsletter-form input {
        padding: 1rem;
        border-radius: var(--radius-pill);
        border: 1px solid #ddd;
        font-family: var(--font-body);
    }
</style>
