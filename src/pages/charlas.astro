import Layout from "../layouts/Layout.astro";

const topics = [
    {
        id: "01",
        title: "Valores, coherencia y decisiones",
        description:
            "Una exploración profunda sobre cómo alinear lo que somos con lo que hacemos. Ideal para equipos que buscan liderazgo consciente.",
    },
    {
        id: "02",
        title: "Hábitos, renuncia y FOMO",
        description:
            "Cómo simplificar para avanzar. El poder de decir 'no' y la construcción de hábitos que sostienen una vida con propósito.",
    },
    {
        id: "03",
        title: "Autenticidad y cambios de vida",
        description:
            "El relato de una transformación real. Herramientas para transitar el cambio sin perder la esencia.",
    },
    {
        id: "04",
        title: "Emprendimiento con Alma",
        description:
            "Más allá de los números. Una visión humana de qué significa crear y sostener un proyecto propio.",
    },
    {
        id: "05",
        title: "Liderazgo consciente",
        description:
            "Guía para líderes que quieren inspirar desde la autenticidad y construir equipos resilientes.",
    },
    {
