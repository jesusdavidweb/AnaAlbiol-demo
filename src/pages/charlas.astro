---

<Layout
    title="Charlas | Ana Albiol"
    description="Charlas y conferencias de Ana Albiol para empresas y eventos. Valores, coherencia, hábitos y autenticidad."
    headerTheme="dark"
>
    <!-- Hero Minimalista -->
    <section class="hero-minimal">
        <div class="hero-wrapper">
            <div class="hero-bg-accent"></div>
            <div class="hero-inner">
                <div class="hero-badge">
                    <span class="badge-text">Charlas</span>
                </div>
                <h1 class="hero-title">Charlas que inspiran</h1>
                <p class="hero-subtitle">
                    Propuestas de valor para empresas y eventos que buscan coherencia y transformación.
                </p>
                <a href="/contacto" class="hero-cta">Solicitar disponibilidad</a>
            </div>
        </div>
        <div class="hero-decorative">
            <div class="deco-circle deco-circle-1"></div>
            <div class="deco-circle deco-circle-2"></div>
            <div class="deco-circle deco-circle-3"></div>
        </div>
    </section>

    <!-- Grid de Tarjetas -->
    <section class="charlas-grid-section">
        <div class="container">
            <div class="charlas-grid">
                {
                    topics.map((topic, index) => (
                        <article class="charla-card" style={`--delay: ${index * 0.1}s`}>
                            <div class="card-image">
                                <div class="placeholder-box">
                                    <span class="placeholder-label">{topic.title}</span>
                                </div>
                                <span class="card-number">{topic.id}</span>
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{topic.title}</h3>
                                <p class="card-description">{topic.description}</p>
                                <a href="/contacto" class="card-link">
                                    <span>Saber más</span>
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M5 12h14M12 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- CTA Newsletter Style -->
    <section class="charlas-cta">
        <div class="cta-wrapper">
            <div class="cta-bg-accent"></div>
            <div class="cta-inner">
                <div class="cta-badge">
                    <span class="badge-text">Charlas</span>
                </div>

                <h2 class="cta-heading">
                    ¿Buscas algo específico?
                </h2>

                <p class="cta-description">
                    Diseño charlas y formaciones a medida para tu evento.
                </p>

                <a href="/contacto" class="cta-button">
                    <span>Contactar para Charlas</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
        </div>
        
        <div class="cta-decorative">
            <div class="deco-circle deco-circle-1"></div>
            <div class="deco-circle deco-circle-2"></div>
            <div class="deco-circle deco-circle-3"></div>
        </div>
    </section>
</Layout>

<script>
    import { inView, animate, stagger } from "motion";

    function initCharlasAnimations() {
        const heroBgAccent = document.querySelector(".hero-bg-accent");
        if (heroBgAccent) {
            animate(
                heroBgAccent,
                { opacity: [0, 1], scale: [0.8, 1] },
                { delay: 0.1, duration: 1, easing: "ease-out" }
            );
        }

        const heroDecoCircles = document.querySelectorAll(".hero-decorative .deco-circle");
        if (heroDecoCircles.length) {
            animate(
                heroDecoCircles,
                { opacity: [0, 1], scale: [0.8, 1] },
                { delay: 0.3, duration: 0.8, easing: [0.17, 0.67, 0.83, 0.67] }
            );
        }

        const heroInner = document.querySelector(".hero-inner");
        if (heroInner) {
            animate(
                Array.from(heroInner.children),
                { opacity: [0, 1], y: [30, 0] },
                { delay: 0.4, duration: 0.6, easing: [0.17, 0.67, 0.83, 0.67] }
            );
        }

        const cards = document.querySelectorAll(".charla-card");
        inView(".charlas-grid", () => {
            animate(
                cards,
                { opacity: [0, 1], y: [40, 0] },
                {
                    delay: stagger(0.1),
                    duration: 0.6,
                    easing: [0.17, 0.67, 0.83, 0.67],
                }
            );
        });

        const ctaBgAccent = document.querySelector(".cta-bg-accent");
        if (ctaBgAccent) {
            inView(ctaBgAccent, () => {
                animate(
                    ctaBgAccent,
                    { opacity: [0, 1], scale: [0.8, 1] },
                    { delay: 0.1, duration: 1, easing: "ease-out" }
                );
            });
        }

        const ctaDecoCircles = document.querySelectorAll(".cta-decorative .deco-circle");
        if (ctaDecoCircles.length) {
            inView(".cta-decorative", () => {
                animate(
                    ctaDecoCircles,
                    { opacity: [0, 1], scale: [0.8, 1] },
                    { delay: 0.3, duration: 0.8, easing: [0.17, 0.67, 0.83, 0.67] }
                );
            });
        }

        const ctaWrapper = document.querySelector(".cta-wrapper");
        if (ctaWrapper) {
            inView(ctaWrapper, () => {
                animate(
                    ctaWrapper.querySelectorAll(".cta-badge, .cta-heading, .cta-description, .cta-button"),
                    { opacity: [0, 1], y: [30, 0] },
                    { duration: 0.6, delay: stagger(0.08) }
                );
            });
        }
    }

    initCharlasAnimations();
    document.addEventListener("astro:after-swap", initCharlasAnimations);
</script>

