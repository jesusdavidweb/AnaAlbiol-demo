---
import Layout from "../layouts/Layout.astro";

const formations = [
    {
        id: "01",
        title: "Al Loro con tu VIDA",
        description:
            "Un sistema con herramientas que enseña a ordenar valores, definir metas, tomar decisiones, salir de las jaulas de pensamiento y entender nuestros miedos para vivir con más coherencia.",
    },
    {
        id: "02",
        title: "Efecto VIDA",
        description:
            "Una membresía de doce meses en la que trabajamos los doce melones más importantes del desarrollo personal para ordenar y alinear nuestra VIDA de la forma más amplia posible.",
    },
    {
        id: "03",
        title: "Reparte Noes como panes",
        description:
            "Un taller intensivo para aprender a decir NO y poder poner los límites que protegerán tu tiempo, tu energía y tu salud mental.",
    },
    {
        id: "04",
        title: "Hábitos Sólidos",
        description:
            "Un programa de cuatro meses para construir los hábitos que te permitirán vivir antes de morir. Una propuesta inversa a lo habitual. Con base, sentido, diseño, estructura, planificación, plan de contingencia e implementación.",
    },
    {
        id: "05",
        title: "Vivir la Muerte",
        description:
            "Un intensivo en el que hablamos del tema más tabú de nuestra sociedad, afrontando la certeza de que nos vamos a morir, aprendiendo a acompañar en la muerte y a transitar el duelo de la forma más amable posible.",
    },
    {
        id: "06",
        title: "Principio",
        description:
            "Una sesión práctica para terminar el año con atención y mucha intención. Nuestro clásico ritual de cierre, comunidad y Principio.",
    },
];
---

<Layout
    title="Formaciones | Ana Albiol"
    description="Formaciones y talleres de Ana Albiol. Herramientas para identificar lo que importa, elegirlo y saltar a la acción."
>
    <!-- Formaciones Editorial Grid -->
    <section id="formaciones" class="formations-editorial">
        <div class="container">
            <header class="section-header">
                <span class="section-label fade-element">Propuestas</span>
                <h2 class="section-title fade-element">Programas y Talleres</h2>
                <p class="section-subtitle fade-element">
                    En los últimos cinco años he creado espacios para identificar lo que importa, 
                    elegirlo, recuperar la ilusión y saltar a la acción.
                </p>
            </header>

            <div class="editorial-grid">
                {
                    formations.map((formation, index) => (
                        <article
                            class={`editorial-item ${index % 2 === 1 ? "reverse" : ""} fade-element`}
                        >
                            <div class="editorial-image">
                                <div class="placeholder-box">
                                    <span class="placeholder-label">
                                        {formation.title}
                                    </span>
                                </div>
                                <span class="image-number">{formation.id}</span>
                            </div>
                            <div class="editorial-content">
                                <h3>{formation.title}</h3>
                                <p>{formation.description}</p>
                                <a href="/en-privado" class="topic-link">
                                    <span>Apúntate</span>
                                    <svg
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>
    </section>

    <section class="charlas-cta">
        <div class="cta-wrapper">
            <div class="cta-bg-accent"></div>
            <div class="cta-inner">
                <div class="cta-badge">
                    <span class="badge-text">Formaciones</span>
                </div>

                <h2 class="cta-heading">
                    ¿Buscas algo específico?
                </h2>

                <p class="cta-description">
                    Diseño formaciones a medida para tu evento o empresa.
                </p>

                <a href="/contacto" class="cta-button">
                    <span>Contactar</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>
        </div>
        
        <div class="cta-decorative">
            <div class="deco-circle deco-circle-1"></div>
            <div class="deco-circle deco-circle-2"></div>
            <div class="deco-circle deco-circle-3"></div>
        </div>
    </section>
</Layout>

<script>
    import { inView, animate, stagger } from "motion";

    function initFormacionesAnimations() {
        /* Section headers */
        const sectionHeaders = document.querySelectorAll(
            ".section-header .fade-element",
        );
        sectionHeaders.forEach((header) => {
            inView(header, () => {
                animate(
                    header,
                    { opacity: [0, 1], y: [40, 0] },
                    { duration: 0.8, easing: [0.17, 0.67, 0.83, 0.67] },
                );
            });
        });

        /* Editorial items */
        const editorialItems = document.querySelectorAll(".editorial-item");
        editorialItems.forEach((item) => {
            inView(item, () => {
                const imageEl = item.querySelector(".editorial-image");
                const contentEl = item.querySelector(".editorial-content");

                if (imageEl) {
                    animate(
                        imageEl,
                        { opacity: [0, 1], x: [-50, 0] },
                        {
                            delay: 0,
                            duration: 0.8,
                            easing: [0.17, 0.67, 0.83, 0.67],
                        },
                    );
                }

                if (contentEl) {
                    animate(
                        contentEl,
                        { opacity: [0, 1], x: [50, 0] },
                        {
                            delay: 0.2,
                            duration: 0.8,
                            easing: [0.17, 0.67, 0.83, 0.67],
                        },
                    );
                }
            });
        });

        /* CTA */
        const ctaDecoCircles = document.querySelectorAll(".cta-decorative .deco-circle");
        if (ctaDecoCircles.length) {
            inView(".cta-decorative", () => {
                animate(
                    ctaDecoCircles,
                    { opacity: [0, 1], scale: [0.8, 1] },
                    { delay: 0.3, duration: 0.8, easing: [0.17, 0.67, 0.83, 0.67] }
                );
            });
        }

        const ctaWrapper = document.querySelector(".cta-wrapper");
        if (ctaWrapper) {
            inView(ctaWrapper, () => {
                animate(
                    ctaWrapper.querySelectorAll(".cta-badge, .cta-heading, .cta-description, .cta-button"),
                    { opacity: [0, 1], y: [30, 0] },
                    { duration: 0.6, delay: stagger(0.08) }
                );
            });
        }
    }

    initFormacionesAnimations();
    document.addEventListener("astro:after-swap", initFormacionesAnimations);
</script>

<style>
    /* ========================================
       HERO EDITORIAL PREMIUM
       ======================================== */
    .hero-editorial {
        min-height: 100vh;
        display: flex;
        align-items: center;
        position: relative;
        background-color: var(--color-secondary);
        overflow: hidden;
        padding: 140px 0 100px;
    }

    .background-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: var(--font-heading);
        font-size: 25vw;
        font-weight: 900;
        color: var(--color-primary);
        opacity: 0;
        white-space: nowrap;
        pointer-events: none;
        z-index: 0;
    }

    .hero-wrapper {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: center;
        gap: 4rem;
        position: relative;
        z-index: 2;
    }

    .hero-text-content {
        max-width: 750px;
    }

    .hero-label {
        display: inline-block;
        font-family: var(--font-body);
        text-transform: uppercase;
        letter-spacing: 5px;
        font-size: 0.8rem;
        margin-bottom: 2rem;
        color: var(--color-primary);
        border-bottom: 1px solid rgba(150, 79, 76, 0.3);
        padding-bottom: 0.5rem;
    }

    .hero-quote {
        margin: 0 0 3rem;
        position: relative;
    }

    .quote-upper {
        font-family: var(--font-heading);
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        line-height: 1.4;
        color: var(--color-text-light);
        margin-bottom: 1.5rem;
        font-style: normal;
    }

    .quote-upper em {
        font-style: normal;
        color: var(--color-primary);
    }

    .quote-lower {
        font-family: var(--font-heading);
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: 1.1;
        color: var(--color-primary);
        font-weight: 500;
    }

    .highlight {
        position: relative;
        display: inline;
    }

    .hero-actions {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .hero-visual {
        position: relative;
        opacity: 0;
    }

    .image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 4/5;
        border-radius: 4px;
        overflow: visible;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 4px;
        position: relative;
        z-index: 2;
        filter: sepia(20%) contrast(105%);
        box-shadow: 30px 30px 60px rgba(0, 0, 0, 0.1);
    }

    .image-accent-border {
        position: absolute;
        top: -20px;
        right: -20px;
        width: 100%;
        height: 100%;
        border: 1px solid var(--color-primary);
        opacity: 0.2;
        z-index: 1;
        border-radius: 4px;
    }

    .scroll-wrapper {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        z-index: 3;
    }

    .scroll-mouse {
        width: 24px;
        height: 40px;
        border: 2px solid var(--color-primary);
        border-radius: 12px;
        position: relative;
        opacity: 0.6;
    }

    .mouse-wheel {
        width: 4px;
        height: 8px;
        background-color: var(--color-primary);
        border-radius: 2px;
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        animation: mouseScroll 2s infinite;
    }

    @keyframes mouseScroll {
        0% { transform: translate(-50%, 0); opacity: 1; }
        100% { transform: translate(-50%, 15px); opacity: 0; }
    }

    .scroll-text {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-primary);
        opacity: 0.6;
    }

    /* ========================================
       EDITORIAL FORMATIONS SECTION
       ======================================== */
    .formations-editorial {
        padding: var(--spacing-xl) 0;
        background-color: var(--color-secondary);
    }

    .section-header {
        margin-bottom: 8rem;
        max-width: 700px;
        text-align: center;
        margin-left: auto;
        margin-right: auto;
    }

    .section-label {
        display: block;
        font-family: var(--font-body);
        text-transform: uppercase;
        letter-spacing: 4px;
        font-size: 0.75rem;
        color: var(--color-primary);
        opacity: 0.6;
        margin-bottom: 1rem;
    }

    .section-title {
        font-size: clamp(2.5rem, 6vw, 4rem);
        margin-bottom: 1.5rem;
        color: var(--color-primary);
        font-style: normal;
    }

    .section-subtitle {
        font-size: 1.25rem;
        line-height: 1.7;
        color: var(--color-text-light);
        opacity: 0.85;
    }

    .editorial-grid {
        display: flex;
        flex-direction: column;
        gap: 10rem;
    }

    .editorial-item {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: center;
    }

    .editorial-item.reverse {
        direction: rtl;
    }

    .editorial-item.reverse .editorial-content {
        direction: ltr;
    }

    .editorial-image {
        position: relative;
    }

    .placeholder-box {
        width: 100%;
        aspect-ratio: 4/5;
        background: linear-gradient(145deg, #e8e5e2 0%, #d8d5d2 100%);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .placeholder-label {
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-align: center;
        padding: 0 1rem;
    }

    .image-number {
        position: absolute;
        top: -1.5rem;
        right: -1.5rem;
        font-family: var(--font-heading);
        font-size: 8rem;
        font-style: normal;
        color: var(--color-primary);
        opacity: 0.08;
        line-height: 1;
        pointer-events: none;
    }

    .editorial-content {
        padding: 2rem 0;
    }

    .editorial-content h3 {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        margin-bottom: 1.5rem;
        line-height: 1.25;
        color: var(--color-primary);
        font-style: normal;
    }

    .editorial-content p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--color-text-light);
        margin-bottom: 2rem;
    }

    .topic-link {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-body);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-primary);
        transition: gap 0.3s ease;
    }

    .topic-link:hover {
        gap: 1.25rem;
    }

    .topic-link svg {
        transition: transform 0.3s ease;
    }

    .topic-link:hover svg {
        transform: translateX(5px);
    }

    /* ========================================
       CTA NEWSLETTER STYLE
       ======================================== */
    .charlas-cta {
        background-color: #964f4c;
        position: relative;
        overflow: hidden;
        padding: var(--spacing-xl) 0;
    }

    .cta-wrapper {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
        padding: 0 2rem;
        z-index: 2;
    }

    .cta-bg-accent {
        position: absolute;
        top: -50%;
        right: -20%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .cta-inner {
        position: relative;
        z-index: 2;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .cta-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 50px;
        margin-bottom: 1.25rem;
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.05);
        opacity: 0;
    }

    .badge-text {
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.9);
    }

    .cta-heading {
        font-family: var(--font-heading);
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: normal;
        line-height: 1.1;
        color: #fff;
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
        opacity: 0;
    }

    .cta-description {
        font-family: var(--font-body);
        font-size: 1.1rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.7);
        max-width: 500px;
        margin-bottom: 2.5rem;
        opacity: 0;
    }

    .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        background: #fff;
        color: #964f4c;
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 50px;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        opacity: 0;
    }

    .cta-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        background: #fff;
        color: #964f4c;
    }

    .cta-button:hover svg {
        transform: translateX(4px);
    }

    .cta-button svg {
        transition: transform 0.3s ease;
    }

    .cta-decorative {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 1;
    }

    .cta-decorative .deco-circle {
        position: absolute;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.12);
        animation: float 20s infinite ease-in-out;
        z-index: 1;
    }

    .cta-decorative .deco-circle-1 {
        width: 450px;
        height: 450px;
        bottom: -150px;
        left: -10%;
        animation-duration: 25s;
    }

    .cta-decorative .deco-circle-2 {
        width: 350px;
        height: 350px;
        top: -10%;
        right: 10%;
        animation-delay: -4s;
    }

    .cta-decorative .deco-circle-3 {
        width: 250px;
        height: 250px;
        bottom: 10%;
        right: -5%;
        background: rgba(255, 255, 255, 0.05);
        animation-delay: -2s;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
        33% { transform: translate(50px, -70px) scale(1.1) rotate(5deg); }
        66% { transform: translate(-30px, 30px) scale(0.9) rotate(-5deg); }
    }

    /* ========================================
       RESPONSIVE
       ======================================== */
    @media (max-width: 1200px) {
        .hero-wrapper {
            gap: 2rem;
        }
        
        .quote-lower {
            font-size: clamp(2rem, 4vw, 3rem);
        }
    }

    @media (max-width: 1024px) {
        .hero-editorial {
            padding: 120px 0 80px;
        }

        .hero-wrapper {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 4rem;
        }

        .hero-text-content {
            max-width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .hero-actions {
            justify-content: center;
        }

        .hero-visual {
            max-width: 500px;
            margin: 0 auto;
        }

        .background-text {
            font-size: 30vw;
        }

        .editorial-item {
            gap: 4rem;
        }

        .image-number {
            font-size: 5rem;
            top: -1rem;
            right: -1rem;
        }
    }

    @media (max-width: 768px) {
        .hero-editorial {
            padding: 100px 0 60px;
        }

        .quote-upper {
            font-size: 1.25rem;
        }

        .quote-lower {
            font-size: 2.25rem;
        }

        .editorial-grid {
            gap: 6rem;
        }

        .editorial-item {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .editorial-item.reverse {
            direction: ltr;
        }

        .image-number {
            font-size: 4rem;
            top: -0.5rem;
            right: 0.5rem;
        }

        .custom-cta {
            margin-top: 6rem;
            padding: 4rem 2rem;
        }

        .section-header {
            margin-bottom: 5rem;
        }

        .cta-description {
            font-size: 1rem;
        }

        .cta-button {
            width: 100%;
            justify-content: center;
        }

        .deco-circle-1 {
            width: 200px;
            height: 200px;
            bottom: -100px;
            left: -80px;
        }

        .hero-decorative .deco-circle-1 {
            width: 200px;
            height: 200px;
            bottom: -100px;
            left: -80px;
        }
    }

    @media (max-width: 480px) {
        .hero-label {
            letter-spacing: 4px;
            font-size: 0.7rem;
        }

        .hero-actions {
            flex-direction: column;
            width: 100%;
        }

        .hero-actions .btn {
            width: 100%;
        }

        .section-label {
            font-size: 0.65rem;
        }
    }
</style>
