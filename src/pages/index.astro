---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import HeroAlternative from "../components/HeroAlternative.svelte";
import ValueProposition from "../components/ValueProposition.astro";
import NavigationCards from "../components/NavigationCards.astro";
import AboutIntro from "../components/AboutIntro.astro";
import SiElRioSuena from "../components/SiElRioSuena.astro";
import Newsletter from "../components/Newsletter.astro";

import heroImg from "../assets/images/WEB_AnaAlbiolJUN25-26.webp";
import bioImg from "../assets/images/PRINT_AnaAlbiol_EA-26.webp";
import panoImg from "../assets/images/PRINT_AnaAlbiolJUN25-20.webp";
---

<Layout title="Ana Albiol | Vivir antes de morir" preloadImage={heroImg.src}>
    <!-- 
      Usamos HeroAlternative tal y como se definió en index-2.astro, haciéndolo la página oficial.
    -->
    <HeroAlternative client:load />

    <ValueProposition />

    <!-- Sección de historia/bio integrada (Imagen + Texto Lado a Lado) -->
    <section class="split-bio section-padding bg-light">
        <div class="container fade-up-banner">
            <div class="split-bio-grid">
                <div class="bio-image-wrapper">
                    <Image
                        src={bioImg}
                        alt="Ana Albiol"
                        class="split-bio-image"
                        loading="lazy"
                        style="object-position: center 20%;"
                        widths={[400, 800, bioImg.width]}
                        sizes="(max-width: 900px) 100vw, 50vw"
                    />
                </div>
                <div class="bio-content-wrapper">
                    <h2 class="mb-4">Escribo mi propia historia</h2>
                    <div class="bio-content">
                        <p>
                            Dejé la perfumería sin saber qué vendría después.
                            Aprendí a base de golpes y de confiar en el
                            siguiente paso.
                        </p>
                        <p>
                            Hoy mi mayor éxito es simple: me acuesto sabiendo que
                            soy fiel a lo que siento.
                        </p>
                        <a href="/quien-soy" class="btn mt-4"
                            >Conoce mi recorrido</a
                        >
                    </div>
                </div>
            </div>
        </div>
    </section>

    <NavigationCards />

    <SiElRioSuena />

    <!-- Banner Lifestyle panorámico (Transición) -->
    <section class="panoramic-transition">
        <div class="panoramic-wrapper">
            <div class="panoramic-viewport">
                <Image
                    src={panoImg}
                    alt="Ana Albiol Lifestyle"
                    class="panoramic-img"
                    loading="lazy"
                    widths={[800, 1200, 1600]}
                    sizes="100vw"
                />
            </div>
        </div>
    </section>

    <Newsletter />

    <!-- Structured Data: Person + WebSite -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "Person",
                    name: "Ana Albiol",
                    url: "https://anaalbiol.com",
                    image: new URL(heroImg.src, Astro.site).href,
                    jobTitle: "Coach y Comunicadora",
                    description:
                        "Desarrollo personal, coherencia y vida. Herramientas para dejar de posponer tu vida.",
                    sameAs: ["https://www.instagram.com/bloganaalbiol/"],
                },
                {
                    "@type": "WebSite",
                    name: "Ana Albiol",
                    url: "https://anaalbiol.com",
                    description:
                        "Web oficial de Ana Albiol. Desarrollo personal, coherencia y vida.",
                    inLanguage: "es",
                },
            ],
        })}
    />
</Layout>

<style>
    /* Section: Split Bio */
    .split-bio {
        background-color: var(--color-background-alt); /* Light background */
        border-top: 1px solid rgba(150, 79, 76, 0.05);
        border-bottom: 1px solid rgba(150, 79, 76, 0.05);
        margin: 4rem 0;
    }

    .split-bio-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
        align-items: center;
    }

    @media (min-width: 900px) {
        .split-bio-grid {
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
        }
    }

    .bio-image-wrapper {
        border-radius: var(--radius-lg, 12px);
        overflow: hidden;
        box-shadow: -15px 15px 0 rgba(150, 79, 76, 0.03); /* Subtle offset shadow */
    }

    .split-bio-image {
        width: 100%;
        height: 115%; /* Taller for subtle parallax */
        min-height: 450px;
        max-height: 700px;
        object-fit: cover;
        display: block;
        margin-top: -7.5%; /* Center vertically */
        will-change: transform;
    }

    .bio-content-wrapper {
        text-align: center;
    }

    @media (min-width: 900px) {
        .bio-content-wrapper {
            text-align: left;
            padding-right: 2rem;
        }
    }

    .bio-content p {
        font-size: 1.15rem;
        line-height: 1.8;
        color: var(--color-text);
        margin-bottom: 1.5rem;
    }

    /* Section: Panoramic Transition */
    .panoramic-transition {
        position: relative;
        width: 100%;
        margin: 0;
        overflow: hidden;
    }

    .panoramic-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 2;
        overflow: hidden;
    }

    .panoramic-viewport {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .panoramic-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transform: scale(1.15) translateX(-3%);
        will-change: transform;
    }

    /* Utilitarios */
    .mb-4 {
        margin-bottom: 2rem;
    }
    .mt-4 {
        margin-top: 2rem;
        display: inline-block;
    }
</style>

<script>
    import { inView, animate, scroll } from "motion";

    function initAnimations() {
        const bannerElements = document.querySelectorAll(".fade-up-banner");
        bannerElements.forEach((el) => {
            const htmlEl = el as HTMLElement;
            htmlEl.style.opacity = "0";
            inView(el, () => {
                animate(
                    el,
                    { opacity: [0, 1], y: [30, 0] },
                    { duration: 0.8, easing: "ease-out" },
                );
            });
        });

        const panoramicWrapper = document.querySelector(".panoramic-wrapper");
        if (panoramicWrapper) {
            inView(panoramicWrapper, () => {
                animate(
                    panoramicWrapper,
                    { opacity: [0, 1], scale: [0.97, 1] },
                    { duration: 1.2, easing: [0.25, 0.46, 0.45, 0.94] },
                );
            });
        }

        const panoramicImg = document.querySelector(".panoramic-img");
        const panoramicSection = document.querySelector(".panoramic-transition");
        if (panoramicImg && panoramicSection) {
            scroll(
                animate(panoramicImg, {
                    scale: [1.15, 1],
                    x: ["-3%", "0%"],
                }),
                {
                    target: panoramicSection,
                    offset: ["start end", "center center"],
                }
            );
            scroll(
                animate(panoramicImg, {
                    y: ["0%", "8%"],
                }),
                {
                    target: panoramicSection,
                    offset: ["center center", "end start"],
                }
            );
        }

        const bioImg = document.querySelector(".split-bio-image");
        const bioSection = document.querySelector(".split-bio");
        if (bioImg && bioSection) {
            scroll(animate(bioImg, { y: ["-5%", "5%"] }), {
                target: bioSection,
                offset: ["start end", "end start"],
            });
        }
    }

    initAnimations();
    document.addEventListener("astro:after-swap", initAnimations);
</script>
