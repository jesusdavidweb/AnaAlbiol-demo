<section class="section-padding bg-light">
    <div class="container fade-up">
        <div class="text-center mb-5 fade-up" style="margin-bottom: 3rem;">
            <h2>Empieza por aquí</h2>
        </div>
        <div class="steps-grid" id="steps-grid">
            <div class="step-item text-center">
                <span
                    class="step-number"
                    style="font-size: 3.5rem; color: var(--color-primary); opacity: 0.15; font-family: var(--font-heading); display: block; margin-bottom: 0.5rem; line-height: 1;"
                    >1</span
                >
                <h3 style="font-size: 1.5rem; margin-top: 1rem;">
                    Entras En Privado
                </h3>
            </div>
            <div class="step-item text-center">
                <span
                    class="step-number"
                    style="font-size: 3.5rem; color: var(--color-primary); opacity: 0.15; font-family: var(--font-heading); display: block; margin-bottom: 0.5rem; line-height: 1;"
                    >2</span
                >
                <h3 style="font-size: 1.5rem; margin-top: 1rem;">
                    Lee, escucha y reflexiona a tu ritmo
                </h3>
            </div>
            <div class="step-item text-center">
                <span
                    class="step-number"
                    style="font-size: 3.5rem; color: var(--color-primary); opacity: 0.15; font-family: var(--font-heading); display: block; margin-bottom: 0.5rem; line-height: 1;"
                    >3</span
                >
                <h3 style="font-size: 1.5rem; margin-top: 1rem;">
                    Cuando estés listo, el resto aparece
                </h3>
            </div>
        </div>
        <div class="text-center fade-up" style="margin-top: 4rem;">
            <a
                href="/en-privado"
                class="btn"
                style="padding: 1rem 3rem; font-size: 1.1rem;"
                >Es aquí: En Privado</a
            >
        </div>
    </div>
</section>

<script>
    import { inView, animate, stagger } from "motion";

    function initNavigationCardsAnimations() {
        const grid = document.getElementById("steps-grid");
        if (grid) {
            inView(grid, () => {
                animate(
                    grid.querySelectorAll(".step-item"),
                    { opacity: [0, 1], y: [50, 0] },
                    {
                        duration: 0.6,
                        delay: stagger(0.2),
                        easing: [0.34, 1.56, 0.64, 1],
                    },
                );
            });
        }
    }

    initNavigationCardsAnimations();
    document.addEventListener("astro:after-swap", initNavigationCardsAnimations);
</script>

<style>
    .step-item {
        opacity: 0;
    }
</style>
