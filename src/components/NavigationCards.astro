<script>
    import { inView, animate, stagger } from "motion";

    const grid = document.getElementById("steps-grid");
    if (grid) {
        inView(grid, () => {
            animate(
                grid.querySelectorAll(".step-item"),
                { opacity: [0, 1], y: [50, 0] },
                {
                    duration: 0.6,
                    delay: stagger(0.2),
                    easing: [0.34, 1.56, 0.64, 1],
                },
            );
        });
    }
</script>

