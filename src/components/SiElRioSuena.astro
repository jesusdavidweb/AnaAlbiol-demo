<section class="rio-suena section-padding">
    <div class="container fade-up">
        <h2 class="text-center mb-5 section-title">Si el río suena, es aquí</h2>
        <div class="ganchos-grid" id="ganchos-container">
            <div class="gancho-card">
                <p>No estás mal, pero tampoco puedes tirar cohetes.</p>
            </div>
            <div class="gancho-card">
                <p>
                    Sabes que quieres vivir de otra forma, aunque aún no sabes
                    cómo narices empezar o no tienes ni un mísero plan.
                </p>
            </div>
            <div class="gancho-card highlight-card">
                <p>
                    <strong
                        >Después de mucho pensar y leerlo todo, ha llegado la
                        hora de mover el trasero.</strong>
                </p>
            </div>
        </div>
    </div>
</section>

<script>
    import { inView, animate, stagger } from "motion";

    const container = document.getElementById("ganchos-container");
    if (container) {
        inView(container, () => {
            animate(
                Array.from(container.children),
                { opacity: [0, 1], y: [40, 0] },
                { duration: 0.8, delay: stagger(0.2) },
            );
        });
    }
</script>

<style>
    .rio-suena {
        background-color: var(--color-background-alt);
        border-top: 1px solid rgba(150, 79, 76, 0.05);
        border-bottom: 1px solid rgba(150, 79, 76, 0.05);
        padding: 5rem 0;
    }

    .section-title {
        color: var(--color-primary);
        font-style: italic;
        margin-bottom: 3rem;
    }

    .ganchos-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 900px) {
        .ganchos-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .gancho-card {
        background: white;
        padding: 3rem 2.5rem;
        border-radius: var(--radius-md);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        border-top: 4px solid transparent;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        opacity: 0;
    }

    .gancho-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.06);
    }

    .gancho-card:nth-child(1) {
        border-top-color: #e6d0ce;
    }
    .gancho-card:nth-child(2) {
        border-top-color: #c59a96;
    }

    .highlight-card {
        background: var(--color-primary);
        color: white;
        border-top-color: var(--color-primary);
    }

    .highlight-card p {
        color: white;
    }

    .gancho-card p {
        font-size: 1.3rem;
        line-height: 1.6;
        margin: 0;
        font-family: var(--font-body);
    }
</style>
