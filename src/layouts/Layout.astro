---
import '../styles/global.css';
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.astro';

import CookieBanner from '../components/CookieBanner.svelte';
import Preloader from '../components/Preloader.svelte';

interface Props {
	title: string;
    description?: string;
    headerTheme?: 'light' | 'dark';
}

const { title, description = "Web oficial de Ana Albiol. Desarrollo personal, coherencia y vida. Herramientas para dejar de posponer tu vida.", headerTheme = "light" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://anaalbiol.com/">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="https://anaalbiol.com/assets/images/WEB_AnaAlbiolJUN25-26.webp">

    <link rel="icon" type="image/jpg" href="/assets/images/Favicon.jpg">
    
    <!-- Using local global.css imported in frontmatter -->
    <script is:inline>
        // Check session storage immediately to avoid preloader flash on navigation
        if (sessionStorage.getItem('ana_albiol_preloader_visited')) {
            document.documentElement.setAttribute('data-preloader-visited', 'true');
        }
    </script>
</head>
<body>
    <Preloader client:load />
    <Header client:load theme={headerTheme} />
    <slot />
    <Footer />
    
    <CookieBanner client:load />
    
    <script>
        import { inView, animate } from "motion";
        
        // Global fade-up animation
        const fadeUpElements = document.querySelectorAll('.fade-up');
        fadeUpElements.forEach(el => {
            inView(el, () => {
                animate(el, { opacity: [0, 1], y: [40, 0] }, { duration: 0.8, easing: "ease-out" });
            });
        });
    </script>
</body>
</html>
