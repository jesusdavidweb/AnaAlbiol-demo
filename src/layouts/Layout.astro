---
import "../styles/global.css";
import Header from "../components/Header.svelte";
import Footer from "../components/Footer.astro";
import { Font } from "astro:assets";

import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";

import CookieBanner from "../components/CookieBanner.svelte";
// Import logo as URL to use in <img src>
import logoUrl from "../assets/images/LOGO_AnaAlbiol_Color.svg?url";

import ogImg from "../assets/images/WEB_AnaAlbiolJUN25-26.webp";

interface Props {
    title: string;
    description?: string;
    headerTheme?: "light" | "dark";
    preloadImage?: string;
}

const {
    title,
    description = "Web oficial de Ana Albiol. Desarrollo personal, coherencia y vida. Herramientas para dejar de posponer tu vida.",
    headerTheme = "light",
    preloadImage,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// FORCE maintenance while temporary homepage is active
const maintenance = true;

---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="canonical" href={canonicalURL.href} />

        <!-- Astro Font Component for Google Fonts -->
        <Font cssVariable="--font-body" preload />
        <Font cssVariable="--font-subtitle" preload />
        <Font cssVariable="--font-heading" preload />

        <!-- Preload LCP hero image if provided -->
        {
            preloadImage && (
                <link
                    rel="preload"
                    as="image"
                    href={preloadImage}
                    type="image/webp"
                />
            )
        }

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta
            property="og:image"
            content={new URL(ogImg.src, Astro.site)}
        />
        <meta property="og:locale" content="es_ES" />
        <meta property="og:site_name" content="Ana Albiol" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
            name="twitter:image"
            content={new URL(ogImg.src, Astro.site)}
        />

        <!-- Security Headers -->
        <meta http-equiv="X-Content-Type-Options" content="nosniff" />
        <meta name="referrer" content="strict-origin-when-cross-origin" />

        <link
            rel="icon"
            type="image/svg+xml"
            href="/images/favicon-ana.svg"
        />

        <!-- View Transitions -->
        <ClientRouter />

        <!-- Using local global.css imported in frontmatter -->
        <script is:inline>
            // Check session storage immediately to avoid preloader flash on navigation
            if (sessionStorage.getItem("ana_albiol_preloader_visited")) {
                document.documentElement.setAttribute(
                    "data-preloader-visited",
                    "true",
                );
            }
        </script>
    </head>
    <body>
        <!-- Header / footer and interactive scripts hidden while maintenance is active -->
        { maintenance ? (
            <main class="maintenance maintenance-home">
                <div class="maintenance-content">
                    <img src={logoUrl} alt="Ana Albiol" class="maintenance-logo" />
                    <h1>En construcción</h1>
                    <p>Estamos realizando mejoras. Volvemos pronto.</p>
                </div>
            </main>
        ) : (
            <main transition:animate={fade({ duration: "0.35s" })}>
                <slot />
            </main>
        ) }

    </body>
</html>
